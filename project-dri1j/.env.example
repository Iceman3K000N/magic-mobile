# Copy to `.env.local` (local) or set the same keys in Vercel → Settings → Environment Variables.
# All keys must come from the SAME Supabase project (Dashboard → Project Settings → API).

# Project URL — must match where you ran magic_mobile_schema.sql
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Browser key (pick one)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Server-only — required for /api/health/supabase, MagicHub PIN API, etc. Never commit real values.
SUPABASE_SECRET_KEY=sb_secret_...
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
